// WorldCup2 — single schema for all chains + domains (architecture)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Minimal league row for Story 1.8 scaffold; extended by later epics.
model League {
  id        String   @id @default(cuid())
  chainId   Int      @map("chain_id")
  title     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([chainId], map: "idx_leagues_chain_id")
  @@map("leagues")
}

/// One-time SIWE nonces (Story 2.2).
model AuthNonce {
  id        String   @id @default(cuid())
  address   String   @map("address")
  nonce     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([address], map: "idx_auth_nonces_address")
  @@map("auth_nonces")
}

/// Server-side SIWE sessions; cookie holds `id` (Story 2.2).
model AuthSession {
  id        String   @id @default(cuid())
  address   String   @map("address")
  chainId   Int      @map("chain_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt], map: "idx_auth_sessions_expires")
  @@map("auth_sessions")
}

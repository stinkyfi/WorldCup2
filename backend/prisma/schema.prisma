// WorldCup2 — single schema for all chains + domains (architecture)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Indexed league row (Story 2.4 browse); populated by indexer / admin in later epics.
model League {
  id                String    @id @default(cuid())
  chainId           Int       @map("chain_id")
  title             String
  contractAddress   String?   @map("contract_address")
  creatorAddress    String?   @map("creator_address")
  creatorDescription String?  @map("creator_description")
  revisionPolicy    String    @default("Locked") @map("revision_policy")
  devFeeBps         Int       @default(0) @map("dev_fee_bps")
  creatorFeeBps     Int       @default(0) @map("creator_fee_bps")
  entryTokenAddress String    @default("0x0000000000000000000000000000000000000000") @map("entry_token_address")
  entryTokenSymbol  String    @default("ETH") @map("entry_token_symbol")
  entryTokenDecimals Int      @default(18) @map("entry_token_decimals")
  entryFeeWei       BigInt    @default(0) @map("entry_fee_wei")
  poolWei           BigInt    @default(0) @map("pool_wei")
  entryCount        Int       @default(0) @map("entry_count")
  maxEntries        Int       @default(1000) @map("max_entries")
  lockAt            DateTime  @map("lock_at")
  featured          Boolean   @default(false)
  promotedUntil     DateTime? @map("promoted_until")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([chainId], map: "idx_leagues_chain_id")
  @@index([featured], map: "idx_leagues_featured")
  @@map("leagues")
}

/// One-time SIWE nonces (Story 2.2).
model AuthNonce {
  id        String   @id @default(cuid())
  address   String   @map("address")
  nonce     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([address], map: "idx_auth_nonces_address")
  @@map("auth_nonces")
}

/// Server-side SIWE sessions; cookie holds `id` (Story 2.2).
model AuthSession {
  id        String   @id @default(cuid())
  address   String   @map("address")
  chainId   Int      @map("chain_id")
  isAdmin   Boolean  @default(false) @map("is_admin")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt], map: "idx_auth_sessions_expires")
  @@map("auth_sessions")
}

/// Per-chain admin whitelist (Story 2.3, FR4–FR5).
model Admin {
  id        String   @id @default(cuid())
  address   String   @map("address")
  chainId   Int      @map("chain_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([address, chainId], map: "uniq_admins_address_chain")
  @@map("admins")
}

/// ERC-20 tokens approved for league entry on a chain (Story 3.1); mirrors platform / indexer view of WhitelistRegistry.
model WhitelistedToken {
  id         String @id @default(cuid())
  chainId    Int    @map("chain_id")
  address    String
  symbol     String
  decimals   Int
  sortOrder  Int    @default(0) @map("sort_order")

  @@unique([chainId, address], map: "uniq_whitelisted_tokens_chain_address")
  @@index([chainId], map: "idx_whitelisted_tokens_chain_id")
  @@map("whitelisted_tokens")
}

// WorldCup2 — single schema for all chains + domains (architecture)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Indexed league row (Story 2.4 browse); populated by indexer / admin in later epics.
model League {
  id                String    @id @default(cuid())
  chainId           Int       @map("chain_id")
  title             String
  contractAddress   String?   @map("contract_address")
  creatorAddress    String?   @map("creator_address")
  creatorDescription String?  @map("creator_description")
  revisionPolicy    String    @default("Locked") @map("revision_policy")
  devFeeBps         Int       @default(0) @map("dev_fee_bps")
  creatorFeeBps     Int       @default(0) @map("creator_fee_bps")
  entryTokenAddress String    @default("0x0000000000000000000000000000000000000000") @map("entry_token_address")
  entryTokenSymbol  String    @default("ETH") @map("entry_token_symbol")
  entryTokenDecimals Int      @default(18) @map("entry_token_decimals")
  entryFeeWei       BigInt    @default(0) @map("entry_fee_wei")
  poolWei           BigInt    @default(0) @map("pool_wei")
  entryCount        Int       @default(0) @map("entry_count")
  maxEntries        Int       @default(1000) @map("max_entries")
  lockAt            DateTime  @map("lock_at")
  featured          Boolean   @default(false)
  promotedUntil     DateTime? @map("promoted_until")
  lastCalculatedAt  DateTime? @map("last_calculated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([chainId], map: "idx_leagues_chain_id")
  @@index([featured], map: "idx_leagues_featured")
  @@map("leagues")
}

/// Off-chain entry payload preimage (stored so indexer can score on ResultsPosted).
model Entry {
  id           String   @id @default(cuid())
  chainId      Int      @map("chain_id")
  leagueAddress String  @map("league_address")
  walletAddress String  @map("wallet_address")
  entryIndex   Int      @map("entry_index")
  entryId      String   @map("entry_id")
  commitment   String   @map("commitment")
  groups       Json     @map("groups_json")
  tiebreakerTotalGoals Int @map("tiebreaker_total_goals")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([chainId, leagueAddress, walletAddress, entryIndex], map: "uniq_entries_chain_league_wallet_index")
  @@index([chainId, leagueAddress], map: "idx_entries_chain_league")
  @@index([walletAddress], map: "idx_entries_wallet")
  @@map("entries")
}

/// Per-group score for an entry (1pt per correct position + 1pt perfect bonus).
model Score {
  id           String   @id @default(cuid())
  chainId      Int      @map("chain_id")
  leagueAddress String  @map("league_address")
  walletAddress String  @map("wallet_address")
  entryIndex   Int      @map("entry_index")
  groupId      Int      @map("group_id")
  points       Int      @map("points")
  perfectBonus Boolean  @default(false) @map("perfect_bonus")
  calculatedAt DateTime @default(now()) @map("calculated_at")

  @@unique([chainId, leagueAddress, walletAddress, entryIndex, groupId], map: "uniq_scores_entry_group")
  @@index([chainId, leagueAddress], map: "idx_scores_chain_league")
  @@index([walletAddress], map: "idx_scores_wallet")
  @@map("scores")
}

/// Per-chain cursor for event replay / crash recovery.
model IndexerState {
  id               String   @id @default(cuid())
  chainId           Int      @unique @map("chain_id")
  lastProcessedBlock BigInt  @default(0) @map("last_processed_block")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("indexer_state")
}

/// One-time SIWE nonces (Story 2.2).
model AuthNonce {
  id        String   @id @default(cuid())
  address   String   @map("address")
  nonce     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([address], map: "idx_auth_nonces_address")
  @@map("auth_nonces")
}

/// Server-side SIWE sessions; cookie holds `id` (Story 2.2).
model AuthSession {
  id        String   @id @default(cuid())
  address   String   @map("address")
  chainId   Int      @map("chain_id")
  isAdmin   Boolean  @default(false) @map("is_admin")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt], map: "idx_auth_sessions_expires")
  @@map("auth_sessions")
}

/// Per-chain admin whitelist (Story 2.3, FR4–FR5).
model Admin {
  id        String   @id @default(cuid())
  address   String   @map("address")
  chainId   Int      @map("chain_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([address, chainId], map: "uniq_admins_address_chain")
  @@map("admins")
}

/// ERC-20 tokens approved for league entry on a chain (Story 3.1); mirrors platform / indexer view of WhitelistRegistry.
model WhitelistedToken {
  id         String @id @default(cuid())
  chainId    Int    @map("chain_id")
  address    String
  symbol     String
  decimals   Int
  sortOrder  Int    @default(0) @map("sort_order")

  @@unique([chainId, address], map: "uniq_whitelisted_tokens_chain_address")
  @@index([chainId], map: "idx_whitelisted_tokens_chain_id")
  @@map("whitelisted_tokens")
}

/// One-time compliance acknowledgment per wallet per league entry flow (Story 4.1).
model ComplianceAcknowledgement {
  id             String   @id @default(cuid())
  leagueId       String   @map("league_id")
  walletAddress  String   @map("wallet_address")
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")

  @@unique([leagueId, walletAddress], map: "uniq_compliance_league_wallet")
  @@index([walletAddress], map: "idx_compliance_wallet_address")
  @@index([leagueId], map: "idx_compliance_league_id")
  @@map("compliance_acknowledgements")
}

/// Story 5.1 — primary oracle cron post logs (per chain + group).
model OraclePost {
  id        String   @id @default(cuid())
  chainId   Int      @map("chain_id")
  groupId   Int      @map("group_id")
  source    String   @default("primary") @map("source") // primary | redundant | manual
  method    String   @map("method") // postResults | setResultsForTesting
  txHash    String?  @map("tx_hash")
  success   Boolean  @default(false)
  postedAt  DateTime @default(now()) @map("posted_at")

  @@index([chainId, groupId], map: "idx_oracle_posts_chain_group")
  @@index([postedAt], map: "idx_oracle_posts_posted_at")
  @@map("oracle_posts")
}

/// Story 5.1 — primary oracle cron error logs (non-fatal; used for alerts in later stories).
model OracleError {
  id        String   @id @default(cuid())
  chainId   Int      @map("chain_id")
  groupId   Int?     @map("group_id")
  message   String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chainId, createdAt], map: "idx_oracle_errors_chain_time")
  @@map("oracle_errors")
}

/// Story 5.4 — Telegram/webhook alert send failures (should never crash monitoring).
model AlertError {
  id        String   @id @default(cuid())
  chainId   Int      @map("chain_id")
  groupId   Int?     @map("group_id")
  message   String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([chainId, createdAt], map: "idx_alert_errors_chain_time")
  @@map("alert_errors")
}

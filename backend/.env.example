# Copy to .env (gitignored). Used by Prisma CLI and the API server.

# PostgreSQL — matches docker-compose.yml at repo root
DATABASE_URL="postgresql://worldcup2:worldcup2_dev@localhost:5433/worldcup2?schema=public"

# HTTP API (Story 1.8)
API_PORT=3001

# Story 2.2 — SIWE + credentialed CORS (comma-separated origins; no wildcard when using cookies)
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# SIWE message `domain` allowlist (hostnames only, comma-separated)
# SIWE_ALLOWED_DOMAINS=localhost:5173,127.0.0.1:5173

# SIWE chain IDs (default Base Sepolia). Include mainnets when using the league creation wizard (Story 3.2):
# SIWE_ALLOWED_CHAIN_IDS=84532,8453,1,146

# Session cookie max-age in ms (default 7 days)
# SESSION_MAX_AGE_MS=604800000

# Set Secure on session cookie (use true in production HTTPS)
# COOKIE_SECURE=false

# Story 2.3 — optional extra chain IDs for SIWE + session re-bind (comma-separated integers)
# SIWE_ALLOWED_CHAIN_IDS=84532,84533

# Bootstrap an admin (Postgres `admins` is per address + chain_id). Use checksummed `address`.
# Example (Hardhat #0 on Base Sepolia): insert via Prisma Studio or SQL after migrate.

# Story 2.4 — public browse uses indexed rows in `leagues`; apply migrations so browse fields exist.

# Story 2.6 — Open Graph canonical URLs and default og:image (absolute). In dev, align with the SPA origin (e.g. http://localhost:5173).
# PUBLIC_APP_ORIGIN=https://your-domain.com

# Optional: absolute path to index.html when not under the default repo layout (tests / containers).
# FRONTEND_INDEX_HTML_PATH=../frontend/index.html

# Vite-only Story 2.6 vars (league HTML proxy + local OG fallback): see frontend/.env.example

# ─────────────────────────────────────────────────────────────
# Story 5.1 — Primary oracle cron (results posting)
# ─────────────────────────────────────────────────────────────
#
# This is intended to run as an external scheduler (system cron / GitHub Actions / etc.)
# that executes `npm run oracle:primary` on a cadence.
#
# NOTE: This initial implementation supports a staging/dev workflow by reading
# `ORACLE_STAGING_GROUPS_JSON` (rather than fetching api-football.com).
#
# Comma-separated chain IDs to post to (e.g. 84532 for Base Sepolia).
# ORACLE_CHAIN_IDS=84532
#
# OracleController address per chain.
# ORACLE_CONTROLLER_84532=0x0000000000000000000000000000000000000000
#
# RPC URL per chain.
# RPC_URL_84532=https://sepolia.base.org
#
# Private key for the authorised oracle wallet (0x-prefixed hex). Keep secret.
# ORACLE_PRIVATE_KEY=0x...
#
# Which contract method to call:
# - postResults (production deployments; requires oracle auth)
# - setResultsForTesting (staging deployments with stagingMode=true)
# ORACLE_POST_METHOD=setResultsForTesting
#
# JSON array of group standings used in staging/dev:
# [
#   { "groupId": 0, "rankings": ["A1","A2","A3","A4"] },
#   ...
#   { "groupId": 11, "rankings": ["L1","L2","L3","L4"] }
# ]
# ORACLE_STAGING_GROUPS_JSON=[...]

# Optional: label for audit logs (defaults to "primary"; redundant cron sets this internally).
# ORACLE_SOURCE=primary

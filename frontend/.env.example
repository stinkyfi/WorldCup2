# WalletConnect Cloud — required for full mobile wallet support.
# https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=

# Backend API (optional). Leave unset in dev to use Vite proxy: /api → http://127.0.0.1:3001
# If set, ensure backend CORS_ORIGIN includes this app's origin so SIWE cookies work (credentials).
# VITE_API_BASE_URL=http://localhost:3001

# Story 2.6 — Vite dev proxies GET /league/0x…40 hex to this origin for SSR Open Graph HTML.
# VITE_LEAGUE_OG_API_ORIGIN=http://127.0.0.1:3001

# Story 2.6 — When the API is down, Vite injects generic OG using this public origin (og:url / og:image).
# VITE_PUBLIC_APP_ORIGIN=http://localhost:5173

# Story 3.2 — LeagueFactory per chain (checksummed 0x…40). Required to submit createLeague on that chain.
# VITE_LEAGUE_FACTORY_8453=
# VITE_LEAGUE_FACTORY_1=
# VITE_LEAGUE_FACTORY_146=

# Story 5.3 — OracleController per chain (checksummed 0x…40). Required for admin manual results posting.
# VITE_ORACLE_CONTROLLER_8453=
# VITE_ORACLE_CONTROLLER_1=
# VITE_ORACLE_CONTROLLER_146=

# Optional — USDC recipient for post-create promotion transfer (same chain USDC contract is used automatically).
# VITE_PROMOTION_RECIPIENT=

# ─── RPC Endpoints ───────────────────────────────────────────────────────────
# Base Sepolia testnet (get from Alchemy/Infura or use public: https://sepolia.base.org)
RPC_URL_BASE_TESTNET=

# Base Mainnet (get from Alchemy/Infura or use public: https://mainnet.base.org)
RPC_URL_BASE_MAINNET=

# Ethereum Sepolia testnet (get from Alchemy/Infura or use public: https://rpc.sepolia.org)
RPC_URL_ETHEREUM_SEPOLIA=

# Ethereum Mainnet (use Alchemy/Infura — no reliable public RPC)
RPC_URL_ETHEREUM_MAINNET=

# Sonic Blaze testnet (public RPC: https://rpc.blaze.soniclabs.com)
RPC_URL_SONIC_TESTNET=

# Sonic Mainnet (public RPC: https://rpc.soniclabs.com)
RPC_URL_SONIC_MAINNET=

# ─── Deployer ─────────────────────────────────────────────────────────────────
# 0x-prefixed private key of the deployer wallet — NEVER commit a real key
DEPLOYER_KEY=0x_your_private_key_here

# ─── Deploy script (scripts/deploy.ts) ────────────────────────────────────────
# Copy this file to .env.base / .env.ethereum / .env.sonic (gitignored) or export in CI.
# Remote networks require ORACLE_ADDRESS and DEV_WALLET_ADDRESS before broadcast.

# Authorised oracle EOA/contract for OracleController
ORACLE_ADDRESS=

# Platform dev wallet (receives creation fees / dev share) for LeagueFactory
DEV_WALLET_ADDRESS=

# OracleController staging mode (true = staging / faster windows)
ORACLE_STAGING_MODE=false

# LeagueFactory economics (wei / bps) — defaults match test fixtures if unset
LEAGUE_FACTORY_CREATION_FEE_WEI=10000000000000000
LEAGUE_FACTORY_DEV_FEE_BPS=200
LEAGUE_FACTORY_CREATOR_FEE_CAP_BPS=300
LEAGUE_FACTORY_MIN_ENTRY_AMOUNT_WEI=1000000000000000000

# ─── Block Explorer API Keys ──────────────────────────────────────────────────
# hardhat-verify uses Etherscan API v2 — a SINGLE key works for all supported chains
# (Ethereum Mainnet, Sepolia, Base, Base Sepolia, etc.)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Sonic chains use their own explorer (SonicScan) — get from https://sonicscan.org/myapikey
SONICSCAN_API_KEY=

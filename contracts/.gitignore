# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Hardhat generated output ─────────────────────────────────────────────────
artifacts/
cache/
dist/
coverage/

# ─── Deployment records ───────────────────────────────────────────────────────
# Generated by deploy scripts — tracked in deployments/ folder (Story 1.7)
# deployments/ is intentionally NOT ignored so addresses are committed per Story 1.7 spec
deployments/.verify-temp/
# Built-in EDR network (`npx hardhat run ...` with no `--network`); not a staging record
deployments/default.json

# ─── Environment files — NEVER commit private keys ────────────────────────────
.env
.env.*
# Allow .env.example to be committed (it contains no real secrets)
!.env.example

# ─── Slither output ───────────────────────────────────────────────────────────
.slither/
slither-report.json
